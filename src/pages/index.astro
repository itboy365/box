---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBox from '../components/SearchBox.astro';
import Section from '../components/Section.astro';
import Contribute from '../components/Contribute.astro';
import sites from '../data/sites.json';

const categories = [
  { key: 'national', title: '生活服务·国家级' },
  { key: 'knowledge', title: '知识学习 · 国内' },
  { key: 'tools', title: '实用在线工具' },
  { key: 'inspiration', title: '灵感 · 推荐' },
  { key: 'international', title: '全球视野' },
];
---

<BaseLayout>
  <div class="container">
    <header class="header">
      <span class="slogan">万物精选 · 纯粹好用</span>
    </header>

    <SearchBox />

    {categories.map((cat) => (
      <Section
        title={cat.title}
        sectionId={`section-${cat.key}`}
        sites={sites.filter(s => s.category === cat.key)}
      />
    ))}

    <Contribute />

    <footer class="footer">
      <div class="statement" style="text-indent: 2em; text-align: left; max-width: 480px; margin: 0 auto;">
        本站为非盈利个人站点，最初只是个人收藏夹，不断整理、完善，变成了现在的数字藏馆。未来也会持续更新。纯粹方便自己，也方便大家。
      </div>
      <div class="statement" style="text-align: left; max-width: 480px; margin: 0 auto; margin-top: 4px;">
        （发现链接打不开？请发送邮件至 admin@wvip.top，我会尽快修复。）
      </div>
    </footer>
  </div>
</BaseLayout>

<style is:global>
  .header .slogan {
    font-size: clamp(28px, 5.5vw, 42px);
    font-weight: 700;
    letter-spacing: 0.06em;
    background: linear-gradient(135deg, #5bc0eb 0%, #9b6dff 50%, #e8b86d 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 20px rgba(120, 150, 240, 0.5));
    margin-bottom: 24px;
    line-height: 1.3;
  }
</style>