<style>
  /* 为投稿区域微调样式 */
  贡献 h2 {
    margin-bottom: 14px; /* 标题和邮箱按钮的间距稍近一点 */
  }

  .contribute .email-line {
    margin-bottom: 14px; /* 邮箱按钮和下方文字的间距稍远一点，形成层次 */
  }

  .contribute .email-btn {
    /* 让邮箱地址看起来更轻量，像一个链接而不是按钮 */
    背景：透明；       /* 去掉背景色 */
    边框：无；
/* 去掉边框 */
    box-shadow: none;              /* 去掉阴影 */
    padding: 0;                    /* 去掉内边距 */
    字体大小: 17px;               /* 字号稍大一点，更清晰 */
    字体粗细：500；              /* 加一点粗度 */
    颜色: var(--accent);          /* 使用强调色 */
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .contribute .email-btn:hover {
    background: transparent;       /* 悬停时保持无背景 */
    border: none;
    box-shadow: none;
    opacity: 0.8;                  /* 悬停时轻微变暗作为反馈 */
  }
</style>
